# Embedding & LLM provider: "mock" (default, no API key needed), "gemini", or "anthropic"
EMBEDDING_PROVIDER=mock

# Required when EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=

# Required when EMBEDDING_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Embedding vector dimension (768 for gemini text-embedding-004, 1536 for voyage-3)
EMBED_DIM=768
